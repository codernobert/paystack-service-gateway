      "response": [
        {
          "name": "Success Response",
          "originalRequest": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/payments/health",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "payments",
                "health"
              ]
            }
          },
          "status": "OK",
          "code": 200,
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n  \"data\": \"OK\",\n  \"message\": \"Paystack payment service is running\",\n  \"success\": true\n}"
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "paymentIntentId",
      "value": "",
      "type": "string",
      "description": "Payment Intent ID from Initialize Payment endpoint (auto-populated)"
    },
    {
      "key": "clientSecret",
      "value": "",
      "type": "string",
      "description": "Client Secret from Initialize Payment endpoint (auto-populated)"
    }
  ]
}

